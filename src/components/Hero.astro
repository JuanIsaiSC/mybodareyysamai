---
//Foto de fondo
//Nombres de los novios
//Fecha Botón "Ver invitación"
import { Image } from 'astro:assets';
import "../styles/global.css"
import ReySamai from "../assets/images/ReySamai_2.jpeg"
---
<div class="relative w-full h-screen">

    <Image
        src={ReySamai}
        alt="Foto de Rey & Samai"
        width={800}
        priority
        class="w-full h-full object-cover"
    />

    <!-- Oscurecer ligeramente la imagen -->
<div
  class="absolute inset-0 bg-linear-to-t from-black/70 via-black/30 to-black/10">
</div>
    <!-- Contenido -->
    <div
        class="absolute inset-0 flex flex-col gap-5 items-center justify-center pt-40"
    >

        <h3 class="animate-title  font-Lora uppercase text-white text-2xl ">
            Nos casamos
        </h3>

        <h2 class="animate-names mt-4 font-MonteCarlo text-[#D8C8A8] max-[361px]:text-5xl text-7xl  ">
            Rey & Samai
        </h2>

        <h4 class="animate-date mt-4 font-Lora uppercase text-white text-2xl ">
            01 de agosto 2026
        </h4>
        

    </div>

</div>
